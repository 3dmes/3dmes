# 3dmes Umgebungsvariablen
# Kopieren Sie diese Datei nach .env und passen Sie die Werte an

# ===========================
# PostgreSQL Datenbank
# ===========================
POSTGRES_DB=mesdb
POSTGRES_USER=mesuser
POSTGRES_PASSWORD=mespassword
POSTGRES_PORT=5432

# ===========================
# 3dmes Anwendung
# ===========================
# ASP.NET Core Umgebung (Production, Development, Staging)
ASPNETCORE_ENVIRONMENT=Production

# 3dmes Version (Docker Image Tag)
THREEMES_VERSION=latest

# ===========================
# Ports
# ===========================
# HTTP Port
HTTP_PORT=80

# MQTT Port (unverschlüsselt)
MQTT_PORT=1883

# MQTT Port (TLS verschlüsselt)
MQTTS_PORT=8883

# ===========================
# SICHERHEITSHINWEISE
# ===========================
# WICHTIG: Ändern Sie alle Passwörter vor der Produktionsnutzung!
# Verwenden Sie sichere Passwörter mit Buchstaben, Zahlen und Sonderzeichen.
# Stellen Sie sicher, dass die .env Datei nicht in die Versionskontrolle gelangt.

